# === Database (Neon) ===
# Pooled connection string from Neon dashboard → Connection details.
# Used by the app at runtime (Drizzle + serverless driver).
DATABASE_URL=

# Unpooled connection string from Neon dashboard.
# Used by drizzle-kit for migrations (push/migrate commands).
DATABASE_URL_UNPOOLED=

# === Database target safety guard ===
# Endpoint IDs used by scripts/verify-db-target.mjs before migrations/seeds.
# These are not secrets. They prevent accidental production DB changes.
EXPECTED_STAGING_NEON_ENDPOINT=ep-twilight-sound-al2b7jsb
EXPECTED_PRODUCTION_NEON_ENDPOINT=ep-young-meadow-aln5ux5m

# === Resend transactional email ===
# API key from https://resend.com/api-keys (free tier: 100 emails/day,
# 3000/month). Leave empty in dev to use fail-soft mode: DB insert
# succeeds, no email sent, server log warning. The contact form will
# still work end-to-end without Resend configured.
RESEND_API_KEY=

# Sender address. Resend's onboarding@resend.dev is sandbox-safe and
# works without DNS setup (Resend default). For production, swap to a
# verified domain like notify@notify.afm.hu after configuring SPF/DKIM/
# DMARC in the Resend dashboard. The from-address is read at runtime,
# so updating .env.local takes effect on the next API call without a
# server restart.
RESEND_FROM_EMAIL=onboarding@resend.dev

# Recipient for contact form notifications. Typically info@afm.hu (M365
# inbox). Leave empty in dev or set to your test inbox.
RESEND_NOTIFY_TO=

# Admin reply test recipient (Preview/Development only). Production
# replies go to the actual customer email; non-production replies are
# forced to this address to avoid emailing real customers during tests.
# REPLY_TEST_RECIPIENT=test-email@example.com

# === ADMIN AUTH (NextAuth.js / Auth.js v5) ===
# Required for the /admin tool. Generate AUTH_SECRET with:
#   openssl rand -base64 32
# The other 3 come from an Azure AD App Registration. See ADMIN_SETUP.md
# for the step-by-step Azure Portal walk-through.
AUTH_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
# Issuer URL pattern: https://login.microsoftonline.com/<tenant-id>/v2.0
AUTH_MICROSOFT_ENTRA_ID_ISSUER=

# === Contact API origin allowlist ===
# Comma-separated list of allowed Origin header values for POSTs to
# /api/contact in production. If unset, defaults to:
#   https://www.afm.hu, https://afm.hu
# Skipped entirely when NODE_ENV !== "production" or VERCEL_ENV ===
# "preview", so local dev + preview deploys aren't blocked. Override
# this when adding a new production domain (e.g., a marketing landing
# page on a different host) without redeploying code.
#   ALLOWED_ORIGINS=https://www.afm.hu,https://afm.hu,https://landing.afm.hu
ALLOWED_ORIGINS=
