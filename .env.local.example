# Copy this file to .env.local for local development.
# Never commit real secrets. Keep local development pointed at staging.

# Database target policy:
# - DATABASE_URL: pooled Neon connection used by the app runtime.
# - DATABASE_URL_UNPOOLED: direct Neon connection used by drizzle-kit.
# For local development both must point at the staging branch.
DATABASE_URL=postgresql://USER:PASSWORD@STAGING-ENDPOINT-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@STAGING-ENDPOINT.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# NextAuth / Auth.js v5 admin login.
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/TENANT_ID/v2.0

# Vercel Blob uploads for admin images and PDFs.
BLOB_READ_WRITE_TOKEN=

# Resend transactional email.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_NOTIFY_TO=

# Optional production contact-form origin allowlist.
ALLOWED_ORIGINS=
