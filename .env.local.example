# Connection strings from Neon/Vercel Postgres dashboard
# Copy this file to .env.local and fill in actual values from Vercel
DATABASE_URL=postgres://USER:PASS@HOST/DBNAME?sslmode=require
DATABASE_URL_UNPOOLED=postgres://USER:PASS@HOST/DBNAME?sslmode=require

# E-mail küldés (Resend - resend.com/api-keys)
RESEND_API_KEY=

# Admin felület jelszava (24-karakteres random string)
ADMIN_PASSWORD=

# Session token aláíró kulcs (64-karakteres random string, openssl rand -base64 64)
SESSION_SECRET=
