{
  "name": "avenir-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:verify-target": "node scripts/verify-db-target.mjs --target staging",
    "db:verify-target:prod": "node scripts/verify-db-target.mjs --target production --allow-production",
    "db:migrate": "node scripts/verify-db-target.mjs --target staging && drizzle-kit migrate",
    "db:migrate:prod": "node scripts/verify-db-target.mjs --target production --allow-production && drizzle-kit migrate",
    "db:push": "node scripts/verify-db-target.mjs --target staging && drizzle-kit push",
    "db:push:prod": "node scripts/verify-db-target.mjs --target production --allow-production && drizzle-kit push",
    "db:seed": "node scripts/verify-db-target.mjs --target staging --runtime-only && tsx scripts/seed.ts",
    "db:seed:prod": "node scripts/verify-db-target.mjs --target production --allow-production --runtime-only && tsx scripts/seed.ts",
    "db:seed-services": "node scripts/verify-db-target.mjs --target staging --runtime-only && tsx scripts/seed-services.ts",
    "db:seed-services:prod": "node scripts/verify-db-target.mjs --target production --allow-production --runtime-only && tsx scripts/seed-services.ts",
    "db:update-certs": "node scripts/verify-db-target.mjs --target staging --runtime-only && tsx scripts/update-certifications-prod.ts",
    "db:update-certs:prod": "node scripts/verify-db-target.mjs --target production --allow-production --runtime-only && tsx scripts/update-certifications-prod.ts",
    "db:update-positions": "node scripts/verify-db-target.mjs --target staging --runtime-only && tsx scripts/update-positions-prod.ts",
    "db:update-positions:prod": "node scripts/verify-db-target.mjs --target production --allow-production --runtime-only && tsx scripts/update-positions-prod.ts",
    "db:import-service-translations": "node scripts/verify-db-target.mjs --target staging --runtime-only && tsx scripts/import-service-translations.ts",
    "qa:preview": "node scripts/qa-preview-smoke.mjs",
    "indexnow:dry-run": "node scripts/submit-indexnow.mjs --dry-run",
    "indexnow:submit": "node scripts/submit-indexnow.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/blob": "^2.3.3",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.2",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "drizzle-kit": "0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
